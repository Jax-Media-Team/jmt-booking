# Google OAuth credentials from your Google Cloud project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# The calendar where new bookings are written. Usually your work calendar email.
GOOGLE_TARGET_CALENDAR_ID=pcruz@jaxmediateam.com

# Comma-separated calendar IDs to check for conflicts. Include the target plus
# any personal/team calendars you've shared with your work account.
# Example: pcruz@jaxmediateam.com,personal@gmail.com,teammate@jaxmediateam.com
GOOGLE_FREEBUSY_CALENDARS=pcruz@jaxmediateam.com

# Resend API key for sending confirmation emails
RESEND_API_KEY=
RESEND_FROM="Patrick Cruz <bookings@jaxmediateam.com>"

# Public site URL (used in confirmation emails)
SITE_URL=https://book.jaxmediateam.com
